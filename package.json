{
  "name": "julia-ai",
  "version": "3.0.1",
  "description": "Julia 3.0 - AI Orchestrator with RTK compression, Auto-DAG parallelism, and 84% token economy",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "julia": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "rm -rf dist coverage",
    "prebuild": "npm run clean && npm run lint",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "julia",
    "orchestrator",
    "ai",
    "agents",
    "rtk",
    "compression",
    "dag",
    "parallelism",
    "token-optimization",
    "cursor",
    "claude-code",
    "copilot",
    "cline"
  ],
  "author": "Lindemberg (bergsaraujo)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nextwaveia/Julia_AI.git"
  },
  "homepage": "https://github.com/nextwaveia/Julia_AI",
  "bugs": {
    "url": "https://github.com/nextwaveia/Julia_AI/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "yaml": "^2.3.1",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "julia": {
    "version": "3.0.1",
    "features": {
      "auto-interpreter": true,
      "compressed-ail": true,
      "auto-dag": true,
      "rtk-injection": true,
      "parallel-execution": true,
      "smart-reports": true
    },
    "supported-ides": [
      "claude-code",
      "cursor",
      "copilot",
      "cline",
      "windsurf",
      "gemini",
      "opencode",
      "pi",
      "hermes",
      "antigravity",
      "kilocode"
    ],
    "target": "84% token reduction, 3x speedup"
  }
}
